# Copy this to infrastructure/.env.production and fill in all values.
# This file is committed. infrastructure/.env.production is gitignored.

APP_NAME=SatView
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://satview.eu
FRONTEND_URL=https://satview.eu
SANCTUM_STATEFUL_DOMAINS=satview.eu

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=satview
DB_USERNAME=satview
DB_PASSWORD=                      # strong random password
DB_ROOT_PASSWORD=                 # strong random password (MySQL root)

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS=admin@satview.eu
MAIL_FROM_NAME=SatView

# Docker image tags (default: latest from GHCR)
BACKEND_IMAGE=ghcr.io/ponastadas/debris-monitor-backend:latest
FRONTEND_IMAGE=ghcr.io/ponastadas/debris-monitor-frontend:latest

# Let's Encrypt — email for certificate expiry notices
ACME_EMAIL=admin@satview.eu

# Space-Track credentials for satellite data sync
SPACE_TRACK_USER=
SPACE_TRACK_PASS=
